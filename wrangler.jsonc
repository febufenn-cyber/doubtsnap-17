{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "doubtsnap-truth-engine",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-13",
  "workers_dev": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "vars": {
    "MODEL_PROVIDER": "mock",
    "PIPELINE_VERSION": "phase1-0.1.0",
    "MAX_IMAGE_BYTES": "10000000"
  }
}
