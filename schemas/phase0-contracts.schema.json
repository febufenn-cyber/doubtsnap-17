{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doubtsnap.local/schemas/phase0-contracts.schema.json",
  "title": "Doubtsnap Phase 0 contracts",
  "type": "object",
  "$defs": {
    "quantity": {
      "type": "object",
      "required": ["name", "value", "unit", "source"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "symbol": {"type": ["string", "null"]},
        "value": {"type": ["number", "string"]},
        "unit": {"type": "string"},
        "source": {"enum": ["observed", "student_confirmed", "inferred"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "object",
      "required": ["image_quality", "transcription", "classification", "solution", "verification", "teaching"],
      "properties": {
        "image_quality": {"type": "number", "minimum": 0, "maximum": 1},
        "transcription": {"type": "number", "minimum": 0, "maximum": 1},
        "classification": {"type": "number", "minimum": 0, "maximum": 1},
        "solution": {"type": "number", "minimum": 0, "maximum": 1},
        "verification": {"type": "number", "minimum": 0, "maximum": 1},
        "teaching": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    },
    "problem": {
      "type": "object",
      "required": ["id", "curriculum", "grade", "subject", "topic", "transcription", "known_values", "required_quantities", "assumptions", "clarification_required"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
        "curriculum": {"type": "string"},
        "grade": {"type": "string"},
        "subject": {"type": "string"},
        "topic": {"type": "string"},
        "language": {"type": "string"},
        "transcription": {"type": "string", "minLength": 1},
        "known_values": {"type": "array", "items": {"$ref": "#/$defs/quantity"}},
        "required_quantities": {"type": "array", "items": {"type": "string"}, "minItems": 1},
        "diagram_elements": {"type": "array", "items": {"type": "string"}},
        "assumptions": {"type": "array", "items": {"type": "string"}},
        "clarification_required": {"type": "boolean"},
        "clarification_reason": {"type": ["string", "null"]},
        "confidence": {"$ref": "#/$defs/confidence"}
      },
      "additionalProperties": false
    },
    "benchmark_item": {
      "type": "object",
      "required": ["id", "source_type", "chapter", "difficulty", "image_quality", "question_type", "canonical_transcription", "canonical_method", "final_answer", "expected_misconceptions", "clarification_required", "risk_tags"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
        "source_type": {"enum": ["synthetic", "textbook", "worksheet", "student_photo", "teacher_created"]},
        "chapter": {"type": "string"},
        "difficulty": {"enum": ["easy", "medium", "hard"]},
        "language": {"type": "string"},
        "image_quality": {"enum": ["clear", "angled", "shadowed", "blurred", "cropped", "glare", "handwritten"]},
        "question_type": {"enum": ["numerical", "conceptual", "diagram", "graph", "check_my_work", "ambiguous"]},
        "canonical_transcription": {"type": "string"},
        "canonical_method": {"type": "array", "items": {"type": "string"}},
        "accepted_alternative_methods": {"type": "array", "items": {"type": "array", "items": {"type": "string"}}},
        "final_answer": {
          "type": ["object", "null"],
          "properties": {
            "value": {"type": ["number", "string", "null"]},
            "unit": {"type": ["string", "null"]},
            "tolerance": {"type": ["number", "null"]}
          },
          "required": ["value", "unit", "tolerance"],
          "additionalProperties": false
        },
        "expected_misconceptions": {"type": "array", "items": {"type": "string"}},
        "clarification_required": {"type": "boolean"},
        "clarification_reason": {"type": ["string", "null"]},
        "risk_tags": {"type": "array", "items": {"type": "string"}},
        "expected_max_error_severity": {"enum": ["S0", "S1", "S2", "S3", "S4"]}
      },
      "additionalProperties": false
    }
  }
}
